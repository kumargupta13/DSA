class Solution {
    public int maxSubArray(int[] nums) {
        int n=nums.length;
        int left=0,right=0,curr=0,max=nums[0];
        if(n==1)
        return nums[0];
        for(int num: nums)
        {
            curr+=num;
            if(curr>max){
                max=curr;
            }
            if(curr<0)
            {
                curr=0;
            }
        }
        return max;
    }
}
