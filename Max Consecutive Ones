class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int n=nums.length;
        int k=0;
        int max=0;
        for(int i=0;i<n;i++)
        {
            if(nums[i]==1)
            k++;
            else
            k=0;
            max=Math.max(k,max);
        }
        return max;
    }
}
