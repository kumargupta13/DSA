class Solution {
    public int[] getSneakyNumbers(int[] nums) {
        int n=nums.length;
        int a[]=new int[2];
        int count[]=new int[nums.length];
        for(int i=0;i<n;i++)
        {
            count[nums[i]]++;
        }
        int k=0;
        for(int i=0;i<n;i++)
        {
            if(count[i]>=2)
            {
                a[k]=i;
                k++;
            }   
        }
        return a;
    }
}
