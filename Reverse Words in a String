class Solution {
    public String reverseWords(String s) {
        StringBuilder sa=new StringBuilder();
        int n=s.length();
        String[] words=s.trim().split("\\s+");
        for(int i=words.length-1;i>=0;i--)
        {
            sa.append(words[i]);
            if(i>0)
            sa.append(" ");
        }

        return sa.toString();
    }
}
