class Solution {
    public int reverse(int x) {
        int sign=1;
        if(x<0)
        sign=-1;
        long n=(Math.abs((long)x));
        long rev=0;
        while(n>0)
        {
            long d=n%10;
            rev=rev*10+d;
            n/=10;
        }
        if(rev>Integer.MAX_VALUE || rev<Integer.MIN_VALUE)
        return 0;
        else
        return (int)rev*sign;
    }
}
