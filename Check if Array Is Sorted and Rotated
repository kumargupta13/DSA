class Solution {
    public boolean check(int[] nums) {
        int n=nums.length;
        if(n==1)
        return true;
        int count=0;
        boolean flag=false;
        for(int i=1;i<2*n;i++)
        {
            if(nums[i%n]>=nums[(i-1)%n])
            count++;
            else count=1;
            if(count==n)
            flag=true;
        }
        return flag;
    }
}
