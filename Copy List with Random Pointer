class Solution {
    public Node copyRandomList(Node head) {
        Node temp=head,copy=null;
        while(temp!=null)
        {
            copy=new Node(temp.val);
            copy.next=temp.next;
            temp.next=copy;
            temp=temp.next.next;
        }
        temp=head;
        Node copy1=null;
        while(temp!=null)
        {
            copy1=temp.next;
            if(temp.random!=null)
            copy1.random=temp.random.next;
            else
            copy1.random=null;
            temp=temp.next.next;
        }
        Node dnode=new Node(-1);
        Node res=dnode;
        temp=head;
        while(temp!=null)
        {
            res.next=temp.next;
            temp.next=temp.next.next;
            res=res.next;
            temp=temp.next;
        }
        return dnode.next;
    }
}
