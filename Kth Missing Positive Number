class Solution {
    public int findKthPositive(int[] arr, int k) {
        int n=arr.length;
        int beg=0,end=n-1,mid=0,missing=0;
        while(beg<=end)
        {
            mid=beg+(end-beg)/2;
            missing=arr[mid]-(mid+1);
            if(missing<k)
            {
                beg=mid+1;
            }
            else
            end=mid-1;
        }
        return beg+k;
    }
}
