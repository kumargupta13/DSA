class Solution {
    public int fib(int n) {
        int memo[]=new int[n+1];
        Arrays.fill(memo,-1);
        return solve(n,memo);
    }
    public int solve(int n, int[] memo)
    {
        if(n==0 || n==1)
        return n;
        else
        {
            if(memo[n]!=-1)
            return memo[n];
            return (solve(n-1,memo)+solve(n-2,memo));
        }
    }
}
