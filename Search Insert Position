class Solution {
    public int searchInsert(int[] nums, int target) {
        int n=nums.length;
        int beg=0,end=n-1,mid=0,idx=n;
        while(beg<=end)
        {
            mid=(beg+end)/2;
            if(nums[mid]>=target)
            {
                idx=mid;
                end=mid-1;
            }
            else
            beg=mid+1;
        }
        return idx;
    }
}
