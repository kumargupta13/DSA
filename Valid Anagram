class Solution {
    public boolean isAnagram(String s, String t) {
        int n=s.length();
        int c[]=new int[26];
        if(n!=t.length())
        return false;
        for(int i=0;i<n;i++)
        {
            c[s.charAt(i)-'a']++;
        }
        for(int i=0;i<n;i++)
        {
            c[t.charAt(i)-'a']--;
        }
        for(int i=0;i<26;i++)
        {
            if(c[i]!=0)
            return false;
        }
        return true;
    }
}
