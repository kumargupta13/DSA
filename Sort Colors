class Solution {
    public void sortColors(int[] nums) {
        int n=nums.length;
        int arr[]=new int[3];
        int k=0;
        for(int i=0;i<n;i++)
        {
            arr[nums[i]]++;
        }
        for(int i=0;i<3;i++)
        {
            while(arr[i]!=0)
            {
                nums[k]=i;
                arr[i]--;
                k++;
            }
        }
    }
}
