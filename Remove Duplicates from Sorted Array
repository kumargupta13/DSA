class Solution {
    public int removeDuplicates(int[] nums) {
        int left=1,right=1;
        int n=nums.length;
        if(n==0)
        return 0;
        for(right=1;right<n;right++)
        {
            if(nums[right]!=nums[right-1])
            {
                nums[left]=nums[right];
                left++;
            }
        }
        return left;
    }
}
