class Solution {
    public int maxProfit(int[] prices) {
        int n=prices.length;
        int maxp=0,curr=prices[0];
        for(int i=0;i<n;i++)
        {
            curr=Math.min(curr,prices[i]);
            if(maxp<prices[i]-curr)
            maxp=prices[i]-curr;
        }
        
        return maxp;
    }
}
