class Solution {
    long m=1000000007;
    public long pow(long n,long x)
    {
        if(x==0)
        return 1;
        long half=pow(n,x/2);
        if(x%2==0)
        return (half*half)%m;
        else
        return (n*(half*half)%m)%m;
    }
    public int countGoodNumbers(long n) {
        return (int)((pow(4,n/2)*pow(5,(n+1)/2))%m);
    }
}
