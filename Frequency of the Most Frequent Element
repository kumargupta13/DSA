class Solution {
    public int maxFrequency(int[] nums, int k) {
        Arrays.sort(nums);
        int res=0,left=0,right=0;
        long total=0;
        for(right=0;right<nums.length;right++)
        {
            total+=nums[right];
            while((long)(right-left+1)*nums[right]>total+k)
            {
                total-=nums[left];
                left++;
            }
            res=Math.max(right-left+1,res);
        }
        return res;
    }
}
