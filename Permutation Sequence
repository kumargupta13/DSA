class Solution {
    public String getPermutation(int n, int k) {
        List<Integer> ls=new ArrayList<>();
        int f=1;
        for(int i=1;i<n;i++)
        {
            f*=i;
            ls.add(i);
        }
        ls.add(n);
        k--;
        String s="";
        while(true)
        {
            s=s+ls.get(k/f);
            ls.remove(k/f);
            if(ls.size()==0)
            break;
            k=k%f;
            f=f/ls.size();
        }
        return s;
    }
}
