class Solution {
    Boolean memo[];
    Set<String> wd;
    public boolean wordBreak(String s, List<String> wordDict) {
        memo=new Boolean[s.length()];
        wd=new HashSet<>(wordDict);
        return solve(0,s);
    }
    public boolean solve(int start,String s)
    {
        if(start==s.length())
            return true;
        if(memo[start]!=null)
        return memo[start];
        for(int end=start+1;end<=s.length();end++)
        {
            String curr=s.substring(start,end);
            if(wd.contains(curr) && solve(end,s))
            {
                return memo[start]=true;
            }
        }
        return memo[start]=false;
    }
}
