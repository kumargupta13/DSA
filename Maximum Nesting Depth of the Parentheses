class Solution {
    public int maxDepth(String s) {
        int n=s.length();
        int c=0,max=0;
        for(int i=0;i<n;i++)
        {
            if(s.charAt(i)=='(')
            c++;
            else if(s.charAt(i)==')')
            {
                max=Math.max(max,c);
                c--;
            }
        }
        return max;
    }
}
