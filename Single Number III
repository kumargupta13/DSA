class Solution {
    public int[] singleNumber(int[] nums) {
        int n=nums.length;
        long xorr=0;
        for(int i=0;i<n;i++)
        {
            xorr^=nums[i];
        }
        int b1=0,b2=0;
        long rightmost=(xorr&xorr-1)^xorr;
        for(int i=0;i<nums.length;i++)
        {
            if(((int)rightmost&nums[i])!=0)
            b1^=nums[i];
            else
            b2^=nums[i];
        }
        int num[]={b1,b2};
        return num;
    }
}
